# Backend Platform — Environment Variables
# Copy this file to .env and fill in all values before running the application.
# Never commit .env to version control.

# Application ---
NODE_ENV=development
APP_NAME=backend-platform
APP_PORT=3000
APP_VERSION=1
LOG_LEVEL=debug

# AES-256 key for encrypting TOTP secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_64_char_hex_string_here_exactly_64_chars_0000000000000000

# Database
DATABASE_URL=postgresql://platform_user:platform_pass@localhost:5432/platform_db
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=platform_user
DB_PASSWORD=platform_pass
DB_DATABASE=platform_db
DB_SSL=false
DB_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=platform:


# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_at_least_32_chars_for_access_secret_here_xxxxxxxxxxxx
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=generate_at_least_32_chars_for_refresh_secret_here_xxxxxxxxxx
JWT_REFRESH_EXPIRY=30d


# Auth Security
BCRYPT_ROUNDS=12
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
MAX_SESSIONS_PER_USER=10


# API Rate Limiting 
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:5173

# Mailer
MAILER_DRIVER=smtp               # smtp | sendgrid | ses
MAILER_FROM=noreply@backend-platform.com
MAILER_FROM_NAME=Platform

# SMTP (use Mailhog locally: host=mailhog port=1025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Frontend
FRONTEND_URL=http://localhost:5173
FRONTEND_VERIFY_EMAIL_PATH=/auth/verify-email
FRONTEND_RESET_PASSWORD_PATH=/auth/reset-password
FRONTEND_INVITE_PATH=/auth/accept-invite

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=usd

# Price IDs from Stripe
STRIPE_PRICE_STARTER_MONTHLY=price_xxxx
STRIPE_PRICE_STARTER_YEARLY=price_xxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxx

STORAGE_DRIVER=local             # local | s3
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE_MB=50

# S3 / Cloudflare R2 / MinIO (if STORAGE_DRIVER=s3)
# S3_BUCKET=platform-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=                   # For MinIO/R2

# AI Gateway
AI_GATEWAY_BASE_URL=http://ai-service:8000
AI_GATEWAY_API_KEY=internal_ai_api_key
AI_GATEWAY_TIMEOUT_MS=30000
AI_GATEWAY_RETRY_ATTEMPTS=3
AI_GATEWAY_CB_THRESHOLD=5

# BullMQ Queues
QUEUE_PREFIX=platform
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_DELAY=5000
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=change_me_in_production

# WebSocket
WS_PORT=3001
WS_CORS_ORIGINS=http://localhost:5173

# Database Seeder
SEED_ADMIN_EMAIL=admin@platform.local
SEED_ADMIN_PASSWORD=Admin123!ChangeThisNow

